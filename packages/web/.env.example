# --- Client (NEXT_PUBLIC_*, inlined into the browser bundle) ---

# WalletConnect project id (free at https://cloud.walletconnect.com). Without it, Injected +
# Coinbase Wallet still work; WalletConnect-based mobile wallets won't connect.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional dedicated RPC. If unset, falls back to public Base/mainnet RPCs.
NEXT_PUBLIC_ALCHEMY_KEY=

# Squads (Mega Pools) contract. Set to the REDEPLOYED address (the one with createPoolWithTickets)
# and its deploy block. Defaults point at the pre-redeploy instance.
NEXT_PUBLIC_SQUADS_ADDRESS=0xb0a41d0fff97d4b12c13e4d329813bb3e0c86dec
NEXT_PUBLIC_SQUADS_DEPLOY_BLOCK=
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_JACKPOT_ADDRESS=0x3bAe643002069dBCbcd62B1A4eb4C4A397d042a2

# --- Server-only (NOT NEXT_PUBLIC_) — settlement keeper / cron ---
KEEPER_PK=
CRON_SECRET=
BASE_RPC_URL=
# Optional: Megapot Data API key for cross-drawing win stats (leaderboard).
MEGAPOT_API_KEY=
